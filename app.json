{
  "expo": {
    "name": "Habix",
    "slug": "Habix",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/ios/AppIcon-1024.png",
    "scheme": "habix",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "icon": "./assets/images/ios/AppIcon-1024.png",
      "supportsTablet": true
    },
    "android": {
      "icon": "./assets/images/ios/AppIcon-1024.png",
      "adaptiveIcon": {
        "backgroundColor": "#1e1b21",
        "foregroundImage": "./assets/images/ios/AppIcon-1024.png",
        "backgroundImage": "./assets/images/ios/AppIcon-1024.png",
        "monochromeImage": "./assets/images/ios/AppIcon-1024.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.swarupcsenits.Habix"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/ios/AppIcon-1024.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/ios/AppIcon-1024.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1e1b21",
          "dark": {
            "backgroundColor": "#1e1b21"
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c41be84f-3bc1-41be-aa26-75054d6390a5"
      }
    }
  }
}
